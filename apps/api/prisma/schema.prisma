datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  USER
  MEMBER
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  passwordHash  String
  role          Role           @default(USER)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  
  refreshTokens RefreshToken[]
  invitations   Invitation[]
}

model RefreshToken {
  id         String   @id @default(uuid())
  token      String   @unique
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  isRevoked  Boolean  @default(false)
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  replacedBy String?  // Для захисту від reuse-атак (будемо бачити, який токет прийшов на заміну)
}

model Invitation {
  id          String    @id @default(uuid())
  email       String    @unique
  token       String    @unique
  role        Role      @default(USER)
  invitedById String
  invitedBy   User      @relation(fields: [invitedById], references: [id])
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  acceptedAt  DateTime?
}